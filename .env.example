# PostgreSQL connection used by the app at request time (Prisma Client).
# On serverless (Vercel), this MUST be a pooled connection string — each API
# route invocation is a short-lived function and can otherwise exhaust
# Postgres's connection limit under concurrent traffic. Use your provider's
# pooled endpoint (Neon: "-pooler" host, Supabase: port 6543, or a PgBouncer
# URL) and append connection_limit=1 for the transaction pooling mode:
#   postgresql://user:pass@host-pooler.example.com/db?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:pass@localhost:5432/interviewlab?schema=public"

# Direct (unpooled) connection used only for schema changes (`bun run
# db:push` / `db:migrate`), which need a session-mode connection that a
# transaction pooler doesn't support. Point this at the same database via
# its non-pooled host/port. Locally this can be identical to DATABASE_URL.
DIRECT_URL="postgresql://user:pass@localhost:5432/interviewlab?schema=public"

# Secret used to sign session JWTs. Must be at least 32 characters.
# Generate one with: openssl rand -base64 32
JWT_SECRET="replace-with-a-random-32-plus-character-secret"

# Public base URL of the deployment (used in metadata/sitemap/emails).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: secret used to authorize the /api/cron/cleanup endpoint (see
# vercel.json). Required in production; without it the endpoint 401s.
CRON_SECRET="replace-with-a-random-secret"

# Optional: override the default rate limits (see src/middleware.ts).
# API_RATE_LIMIT_MAX=60
# AUTH_RATE_LIMIT_MAX=10

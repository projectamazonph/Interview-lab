generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL should point at a pooled connection (e.g. PgBouncer,
  // Neon/Supabase pooler) since API routes run as short-lived serverless
  // functions that would otherwise each open their own Postgres connection.
  // DIRECT_URL is the unpooled connection used for `db:push`/`db:migrate`,
  // which need a session-mode connection. See docs/DEPLOYMENT.md.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String?
  subscriptionTier String   @default("free")
  isAdmin          Boolean  @default(false)
  emailVerified    Boolean  @default(false)
  // Bumped on logout and password reset to invalidate every previously
  // issued JWT for this user (the JWT's `v` claim must match this value).
  tokenVersion     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profile           UserProfile?
  resumes           Resume[]
  coverLetters      CoverLetter[]
  interviewSessions InterviewSession[]
  agentRuns         AgentRun[]
  guideProgress     GuideProgress[]
}

model AppSetting {
  key       String @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  targetRole      String?
  experienceLevel String?
  toolsKnown      String?
  weakAreas       String?
  interviewDate   String?
  confidenceLevel String?
  resumeStatus    String?
  country         String?
  onboardingDone  Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Question {
  id                 String  @id @default(cuid())
  role               String
  difficulty         String
  type               String
  skillArea          String
  question           String
  whyEmployersAsk    String?
  strongAnswerPoints String?
  weakAnswerWarnings String?
  sampleAnswer       String?
  answerFormat       String?
  timeLimit          Int?
  status             String  @default("published")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  attempts QuestionAttempt[]

  @@index([status, role, difficulty])
}

model InterviewSession {
  id           String    @id @default(cuid())
  userId       String
  mode         String
  targetRole   String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  overallScore Float?
  transcript   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts QuestionAttempt[]

  @@index([userId])
}

model QuestionAttempt {
  id              String  @id @default(cuid())
  sessionId       String
  questionId      String
  userAnswer      String
  aiFeedback      String?
  score           Float?
  rubricBreakdown String?
  createdAt       DateTime @default(now())

  session  InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question         @relation(fields: [questionId], references: [id])

  @@index([sessionId])
  @@index([questionId])
}

model Resume {
  id              String   @id @default(cuid())
  userId          String
  originalText    String?
  targetRole      String?
  score           Float?
  improvedVersion String?
  truthFlags      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CoverLetter {
  id              String   @id @default(cuid())
  userId          String
  jobDescription  String?
  tone            String?
  generatedLetter String?
  truthFlags      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Assessment {
  id          String   @id @default(cuid())
  title       String
  role        String
  difficulty  String
  description String?
  datasetInfo String?
  answerKey   String?
  rubric      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Download {
  id            String   @id @default(cuid())
  title         String
  fileType      String
  role          String
  description   String?
  fileName      String
  accessTier    String   @default("free")
  category      String   @default("Other")
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AgentRun {
  id          String   @id @default(cuid())
  userId      String
  agentType   String
  input       String?
  output      String?
  safetyFlags String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Guide {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  level     String
  role      String
  content   String
  status    String   @default("published")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress GuideProgress[]
}

model GuideProgress {
  id         String   @id @default(cuid())
  userId     String
  guideId    String
  completed  Boolean  @default(false)
  checklist  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guide Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([userId, guideId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  // "email_verification" or "password_reset" — tokens for each purpose are
  // tracked separately so requesting one doesn't invalidate the other.
  purpose   String   @default("email_verification")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(1)
  resetTime DateTime
  createdAt DateTime @default(now())

  @@index([resetTime])
}
